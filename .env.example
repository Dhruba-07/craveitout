# Anthropic Claude API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (optional — defaults to claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Restrict the /api/claude endpoint to your own domain (optional — defaults to *)
# Set this to your Vercel deployment URL in production, e.g.:
# ALLOWED_ORIGIN=https://craveitout.vercel.app
ALLOWED_ORIGIN=*
